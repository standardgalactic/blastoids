itation-32">, which acts as a categorical boundary to prevent non-deterministic branches or "logical singularities"</span></span><span data-path-to-node="0,6"><span class="citation-32 citation-end-32"><source-footnote ng-version="0.0.0-PLACEHOLDER" _nghost-ng-c1245605952=""><sup _ngcontent-ng-c1245605952="" class="superscript" data-turn-source-index="2"><!----></sup></source-footnote><source-footnote ng-version="0.0.0-PLACEHOLDER" _nghost-ng-c1245605952=""><sup _ngcontent-ng-c1245605952="" class="superscript" data-turn-source-index="2"><!----></sup></source-footnote><source-footnote ng-version="0.0.0-PLACEHOLDER" _nghost-ng-c1245605952=""><sup _ngcontent-ng-c1245605952="" class="superscript" data-turn-source-index="2"><!----></sup></source-footnote><source-footnote ng-version="0.0.0-PLACEHOLDER" _nghost-ng-c1245605952=""><sup _ngcontent-ng-c1245605952="" class="superscript" data-turn-source-index="2"><!----></sup></source-footnote></span></span><span data-path-to-node="0,7">.</span><sources-carousel-inline ng-version="0.0.0-PLACEHOLDER" _nghost-ng-c3996440800=""><source-inline-chip _ngcontent-ng-c3996440800="" _nghost-ng-c46611929="" class="ng-star-inserted"><div _ngcontent-ng-c46611929="" class="source-inline-chip-container ng-star-inserted"><!----><button _ngcontent-ng-c46611929="" cdkoverlayorigin="" class="button multiple-button ng-star-inserted" aria-label="View source details. Opens side panel." jslog="262206;track:generic_click"><!----><!----><span _ngcontent-ng-c46611929="" hide-from-message-actions="" class="button-label gds-label-m hide-from-message-actions ng-star-inserted"><mat-icon _ngcontent-ng-c46611929="" role="img" fonticon="link" class="mat-icon notranslate symbol gds-icon-s google-symbols mat-ligature-font mat-icon-no-color" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="link"></mat-icon>+4</span><!----><!----><!----></button><!----><!----><!----></div><!----><!----><!----><!----><!----></source-inline-chip><!----><!----><!----><
ffset-2 [&amp;_h2:not(.not-prose):first-child]:mt-0 [&amp;_h3:not(.not-prose):first-child]:mt-0 [&amp;_h4:not(.not-prose):first-child]:mt-0"><p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">\section{Structural Non-Equivalence via Extension-Monotone Consistency}</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">Let <span class="katex"><span class="katex-mathml"><math xmlns="http://www.w3.org/1998/Math/MathML"><semantics><mrow><mi mathvariant="script">X</mi></mrow><annotation encoding="application/x-tex">  \mathcal{X}  </annotation></semantics></math></span><span class="katex-html" aria-hidden="true"><span class="base"><span class="strut" style="height: 0.6833em;"></span><span class="mord mathcal" style="margin-right: 0.14643em;">X</span></span></span></span> be a state space and <span class="katex"><span class="katex-mathml"><math xmlns="http://www.w3.org/1998/Math/MathML"><semantics><mrow><mi mathvariant="script">H</mi></mrow><annotation encoding="application/x-tex">  \mathcal{H}  </annotation></semantics></math></span><span class="katex-html" aria-hidden="true"><span class="base"><span class="strut" style="height: 0.6833em;"></span><span class="mord mathcal" style="margin-right: 0.00965em;">H</span></span></span></span> the space of histories. We distinguish systems not by memory capacity, but by a structural property of admissibility under extension.</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">\subsection{Extension-Monotone Consistency}</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">Let <span class="katex"><span class="katex-mathml"><math xmlns="http://www.w3.org/1998/Math/MathML"><semantics><mrow><mi>╬║</mi><mo>:</mo><mi mathvariant="script">X</mi><mo>├Ś</mo><mi mathvariant="script">X</mi><mo>ŌåÆ</mo><mrow><mn>0</mn><mo separator="true">,</mo><mn>1</mn></mrow></mrow><annotation encoding="application/x-tex">  \kappa : \mathcal{X} \times \mathcal{X} \to {0,1}  </annotation></semantics></math></span><span class="katex-html" aria-hidden="true"><span class="base"><span class="strut" style="height: 0.4306em;"></span><span class="mord mathnormal">╬║</span><span class="mspace" style="margin-right: 0.2778em;"></span><span class="mrel">:</span><span class="mspace" style="margin-right: 0.2778em;"></span></span><span class="base"><span class="strut" style="height: 0.7667em; vertical-align: -0.0833em;"></span><span class="mord mathcal" style="margin-right: 0.14643em;">X</span><span class="mspace" style="margin-right: 0.2222em;"></span><span class="mbin">├Ś</span><span class="mspace" style="margin-right: 0.2222em;"></span></span><span class="base"><span class="strut" style="height: 0.6833em;"></span><span class="mord mathcal" style="margin-right: 0.14643em;">X</span><span class="mspace" style="margin-right: 0.2778em;"></span><span class="mrel">ŌåÆ</span><span class="mspace" style="margin-right: 0.2778em;"></span></span><span class="base"><span class="strut" style="height: 0.8389em; vertical-align: -0.1944em;"></span><span class="mord"><span class="mord">0</span><span class="mpunct">,</span><span class="mspace" style="margin-right: 0.1667em;"></span><span class="mord">1</span></span></span></span></span> be a compatibility relation. Define global consistency of a history <span class="katex"><span class="katex-mathml"><math xmlns="http://www.w3.org/1998/Math/MathML"><semantics><mrow><msub><mi>H</mi><mi>t</mi></msub><mo>=</mo><mo stretchy="false">(</mo><msub><mi>x</mi><mn>1</mn></msub><mo separator="true">,</mo><mo>ŌĆ”</mo><mo separator="true">,</mo><msub><mi>x</mi><mi>t</mi></msub><mo stretchy="false">)</mo></mrow><annotation encoding="application/x-tex">  H_t = (x_1, \dots, x_t)  </annotation></semantics></math></span><span class="katex-html" aria-hidden="true"><span class="base"><span class="strut" style="height: 0.8333em; vertical-align: -0.15em;"></span><span class="mord"><span class="mord mathnormal" style="margin-right: 0.08125em;">H</span><span class="msupsub"><span class="vlist-t vlist-t2"><span class="vlist-r"><span class="vlist" style="height: 0.2806em;"><span style="top: -2.55em; margin-left: -0.0813em; margin-right: 0.05em;"><span class="pstrut" style="height: 2.7em;"></span><span class="sizing reset-size6 size3 mtight"><span class="mord mathnormal mtight">t</span></span></span></span><span class="vlist-s">ŌĆŗ</span></span><span class="vlist-r"><span class="vlist" style="height: 0.15em;"><span></span></span></span></span></span></span><span class="mspace" style="margin-right: 0.2778em;"></span><span class="mrel">=</span><span class="mspace" style="margin-right: 0.2778em;"></span></span><span class="base"><span class="strut" style="height: 1em; vertical-align: -0.25em;"></span><span class="mopen">(</span><span class="mord"><span class="mord mathnormal">x</span><span class="msupsub"><span class="vlist-t vlist-t2"><span class="vlist-r"><span class="vlist" style="height: 0.3011em;"><span style="top: -2.55em; margin-left: 0em; margin-right: 0.05em;"><span class="pstrut" style="height: 2.7em;"></span><span class="sizing reset-size6 size3 mtight"><span class="mord mtight">1</span></span></span></span><span class="vlist-s">ŌĆŗ</span></span><span class="vlist-r"><span class="vlist" style="height: 0.15em;"><span></span></span></span></span></span></span><span class="mpunct">,</span><span class="mspace" style="margin-right: 0.1667em;"></span><span class="minner">ŌĆ”</span><span class="mspace" style="margin-right: 0.1667em;"></span><span class="mpunct">,</span><span class="mspace" style="margin-right: 0.1667em;"></span><span class="mord"><span class="mord mathnormal">x</span><span class="msupsub"><span class="vlist-t vlist-t2"><span class="vlist-r"><span class="vlist" style="height: 0.2806em;"><span style="top: -2.55em; margin-left: 0em; margin-right: 0.05em;"><span class="pstrut" style="height: 2.7em;"></span><span class="sizing reset-size6 size3 mtight"><span class="mord mathnormal mtight">t</span></span></span></span><span class="vlist-s">ŌĆŗ</span></span><span class="vlist-r"><span class="vlist" style="height: 0.15em;"><span></span></span></span></span></span></span><span class="mclose">)</span></span></span></span> as:
[
\forall i,j \le t,\quad \kappa(x_i, x_j) = 1.
]</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">\begin{definition}[Extension-Monotone System]
A system is extension-monotone if for every admissible extension <span class="katex"><span class="katex-mathml"><math xmlns="http://www.w3.org/1998/Math/MathML"><semantics><mrow><msub><mi>x</mi><mrow><mi>t</mi><mo>+</mo><mn>1</mn></mrow></msub></mrow><annotation encoding="application/x-tex">  x_{t+1}  </annotation></semantics></math></span><span class="katex-html" aria-hidden="true"><span class="base"><span class="strut" style="height: 0.6389em; vertical-align: -0.2083em;"></span><span class="mord"><span class="mord mathnormal">x</span><span class="msupsub"><span class="vlist-t vlist-t2"><span class="vlist-r"><span class="vlist" style="height: 0.3011em;"><span style="top: -2.55em; margin-left: 0em; margin-right: 0.05em;"><span class="pstrut" style="height: 2.7em;"></span><span class="sizing reset-size6 size3 mtight"><span class="mord mtight"><span class="mord mathnormal mtight">t</span><span class="mbin mtight">+</span><span class="mord mtight">1</span></span></span></span></span><span class="vlist-s">ŌĆŗ</span></span><span class="vlist-r"><span class="vlist" style="height: 0.2083em;"><span></span></span></span></span></span></span></span></span></span>:
[
\forall i \le t,\quad \kappa(x_{t+1}, x_i) = 1,
]
and this condition is preserved for all future extensions.
\end{definition}</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">Thus consistency is not evaluated locally, but globally over the entire trajectory, and is preserved under all extensions.</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">\subsection{Local vs Global Constraint Systems}</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">A system is locally constrained if admissibility is determined by a function:
[
\mathcal{C}k(x{t+1}, x_{t-k+1}, \dots, x_t),
]
for some finite <span class="katex"><span class="katex-mathml"><math xmlns="http://www.w3.org/1998/Math/MathML"><semantics><mrow><mi>k</mi></mrow><annotation encoding="application/x-tex">  k  </annotation></semantics></math></span><span class="katex-html" aria-hidden="true"><span class="base"><span class="strut" style="height: 0.6944em;"></span><span class="mord mathnormal" style="margin-right: 0.03148em;">k</span></span></span></span>.</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">Such systems may possess arbitrarily large memory, but constraints are enforced only over finite windows.</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">\subsection{Failure of Global Consistency in Local Systems}</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">\begin{theorem}[Violation under Finite-Window Constraints]
Let a system enforce constraints only over windows of size <span class="katex"><span class="katex-mathml"><math xmlns="http://www.w3.org/1998/Math/MathML"><semantics><mrow><mi>k</mi></mrow><annotation encoding="application/x-tex">  k  </annotation></semantics></math></span><span class="katex-html" aria-hidden="true"><span class="base"><span class="strut" style="height: 0.6944em;"></span><span class="mord mathnormal" style="margin-right: 0.03148em;">k</span></span></span></span>. Then there exist sequences <span class="katex"><span class="katex-mathml"><math xmlns="http://www.w3.org/1998/Math/MathML"><semantics><mrow><msub><mi>x</mi><mi>t</mi></msub></mrow><annotation encoding="application/x-tex">  {x_t}  </annotation></semantics></math></span><span class="katex-html" aria-hidden="true"><span class="base"><span class="strut" style="height: 0.5806em; vertical-align: -0.15em;"></span><span class="mord"><span class="mord"><span class="mord mathnormal">x</span><span class="msupsub"><span class="vlist-t vlist-t2"><span class="vlist-r"><span class="vlist" style="height: 0.2806em;"><span style="top: -2.55em; margin-left: 0em; margin-right: 0.05em;"><span class="pstrut" style="height: 2.7em;"></span><span class="sizing reset-size6 size3 mtight"><span class="mord mathnormal mtight">t</span></span></span></span><span class="vlist-s">ŌĆŗ</span></span><span class="vlist-r"><span class="vlist" style="height: 0.15em;"><span></span></span></span></span></span></span></span></span></span></span> such that:
[
\kappa(x_i, x_j) = 1 \text{ for all } |i-j| \le k,
]
but
[
\exists i,j \text{ with } |i-j| &gt; k \text{ such that } \kappa(x_i, x_j) = 0.
]
\end{theorem}</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">\begin{proof}
Construct a sequence of states where each consecutive block of length <span class="katex"><span class="katex-mathml"><math xmlns="http://www.w3.org/1998/Math/MathML"><semantics><mrow><mi>k</mi></mrow><annotation encoding="application/x-tex">  k  </annotation></semantics></math></span><span class="katex-html" aria-hidden="true"><span class="base"><span class="strut" style="height: 0.6944em;"></span><span class="mord mathnormal" style="margin-right: 0.03148em;">k</span></span></span></span> is mutually compatible, but introduce incompatibility between distant elements. This is always possible when <span class="katex"><span class="katex-mathml"><math xmlns="http://www.w3.org/1998/Math/MathML"><semantics><mrow><mi>╬║</mi></mrow><annotation encoding="application/x-tex">  \kappa  </annotation></semantics></math></span><span class="katex-html" aria-hidden="true"><span class="base"><span class="strut" style="height: 0.4306em;"></span><span class="mord mathnormal">╬║</span></span></span></span> is not transitive over arbitrarily long chains.
\end{proof}</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">Thus local enforcement cannot guarantee global consistency, regardless of memory size.</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">\subsection{Non-Simulability under Consistency Constraints}</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">\begin{theorem}[Structural Non-Simulability]
No system enforcing only local or finite-window constraints can simulate an extension-monotone system that enforces global consistency, even if the former has arbitrarily large but finite memory.
\end{theorem}</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">\begin{proof}
Assume a local system simulates a global one. Then for any history <span class="katex"><span class="katex-mathml"><math xmlns="http://www.w3.org/1998/Math/MathML"><semantics><mrow><msub><mi>H</mi><mi>t</mi></msub></mrow><annotation encoding="application/x-tex">  H_t  </annotation></semantics></math></span><span class="katex-html" aria-hidden="true"><span class="base"><span class="strut" style="height: 0.8333em; vertical-align: -0.15em;"></span><span class="mord"><span class="mord mathnormal" style="margin-right: 0.08125em;">H</span><span class="msupsub"><span class="vlist-t vlist-t2"><span class="vlist-r"><span class="vlist" style="height: 0.2806em;"><span style="top: -2.55em; margin-left: -0.0813em; margin-right: 0.05em;"><span class="pstrut" style="height: 2.7em;"></span><span class="sizing reset-size6 size3 mtight"><span class="mord mathnormal mtight">t</span></span></span></span><span class="vlist-s">ŌĆŗ</span></span><span class="vlist-r"><span class="vlist" style="height: 0.15em;"><span></span></span></span></span></span></span></span></span></span>, admissibility must ensure:
[
\forall i \le t,\quad \kappa(x_{t+1}, x_i) = 1.
]</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">However, the local system can only verify compatibility over finite subsets. By the previous theorem, there exist histories for which all local constraints are satisfied while global consistency is violated. Therefore the simulation fails.
\end{proof}</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">\subsection{Independence from Memory Capacity}</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">The distinction does not arise from memory size. A system may store the entire history but fail to enforce global consistency if its constraint evaluation is local or approximate.</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">Conversely, an extension-monotone system may be approximated with summaries only if those summaries preserve all pairwise compatibility relations, which in general requires structure beyond finite compression.</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">Thus the distinction is structural: it concerns the \emph{form of constraint enforcement}, not the \emph{amount of stored information}.</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">\subsection{Dynamical Consequences}</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">In extension-monotone systems:
\begin{itemize}
\item admissible trajectories form a globally consistent subset of <span class="katex"><span class="katex-mathml"><math xmlns="http://www.w3.org/1998/Math/MathML"><semantics><mrow><mi mathvariant="script">H</mi></mrow><annotation encoding="application/x-tex">  \mathcal{H}  </annotation></semantics></math></span><span class="katex-html" aria-hidden="true"><span class="base"><span class="strut" style="height: 0.6833em;"></span><span class="mord mathcal" style="margin-right: 0.00965em;">H</span></span></span></span>,
\item contradictions are excluded at all scales,
\item path dependence induces persistent structural differentiation.
\end{itemize}</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">In local systems:
\begin{itemize}
\item compatibility may hold locally but fail globally,
\item long-range inconsistencies accumulate,
\item trajectories may converge to indistinguishable or contradictory regimes.
\end{itemize}</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">\subsection{Conclusion}</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">The distinction between binding and non-binding systems is therefore not reducible to memory capacity or path dependence. It is characterized by the presence or absence of extension-monotone global consistency constraints. This property cannot be enforced by any system whose admissibility evaluation is reducible to finite or local conditions, regardless of available memory.</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">\section{Local Constraint Systems, Global Consistency, and the Finite-Type Boundary}</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">The preceding distinction between extension-monotone systems and locally constrained systems may invite an immediate objection. There exist many domains in mathematics, computation, and physics in which global regularity is indeed enforced by local rules. Cellular automata, finite automata, nearest-neighbor lattice systems, type systems with local inference rules, and subshifts of finite type all derive large-scale order from bounded local conditions. If this is so, then the claim that local systems cannot enforce global consistency would be too strong.</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">The appropriate conclusion is therefore not that local systems are in principle incapable of global consistency, but that such consistency is achievable locally only under a specific structural condition. The purpose of this section is to isolate that condition precisely.</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">Let <span class="katex"><span class="katex-mathml"><math xmlns="http://www.w3.org/1998/Math/MathML"><semantics><mrow><mi mathvariant="script">X</mi></mrow><annotation encoding="application/x-tex">  \mathcal{X}  </annotation></semantics></math></span><span class="katex-html" aria-hidden="true"><span class="base"><span class="strut" style="height: 0.6833em;"></span><span class="mord mathcal" style="margin-right: 0.14643em;">X</span></span></span></span> be a finite or countable alphabet of admissible elementary states, and let <span class="katex"><span class="katex-mathml"><math xmlns="http://www.w3.org/1998/Math/MathML"><semantics><mrow><mi mathvariant="script">H</mi><mo>=</mo><msub><mo>Ōŗā</mo><mrow><mi>t</mi><mo>Ōēź</mo><mn>0</mn></mrow></msub><msup><mi mathvariant="script">X</mi><mi>t</mi></msup></mrow><annotation encoding="application/x-tex">  \mathcal{H} = \bigcup_{t \ge 0} \mathcal{X}^t  </annotation></semantics></math></span><span class="katex-html" aria-hidden="true"><span class="base"><span class="strut" style="height: 0.6833em;"></span><span class="mord mathcal" style="margin-right: 0.00965em;">H</span><span class="mspace" style="margin-right: 0.2778em;"></span><span class="mrel">=</span><span class="mspace" style="margin-right: 0.2778em;"></span></span><span class="base"><span class="strut" style="height: 1.1884em; vertical-align: -0.3949em;"></span><span class="mop"><span class="mop op-symbol small-op" style="position: relative; top: 0em;">Ōŗā</span><span class="msupsub"><span class="vlist-t vlist-t2"><span class="vlist-r"><span class="vlist" style="height: 0.1514em;"><span style="top: -2.4003em; margin-left: 0em; margin-right: 0.05em;"><span class="pstrut" style="height: 2.7em;"></span><span class="sizing reset-size6 size3 mtight"><span class="mord mtight"><span class="mord mathnormal mtight">t</span><span class="mrel mtight">Ōēź</span><span class="mord mtight">0</spa